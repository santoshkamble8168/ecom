{
  "name": "ecom-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade commerce platform monorepo (storefront, admin, API, worker) plus a reusable AI engineering workspace.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f",
    "db:generate": "pnpm --filter @ecom/api prisma:generate",
    "db:migrate": "pnpm --filter @ecom/api prisma:migrate",
    "db:seed": "pnpm --filter @ecom/api prisma:seed",
    "framework:generate": "python scripts/generate_ai_framework.py",
    "framework:validate": "python scripts/validate_ai_framework.py"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "ecommerce",
    "nextjs",
    "nestjs",
    "monorepo",
    "ai-engineering",
    "cursor"
  ],
  "license": "UNLICENSED"
}
